{
  "name": "@orqastudio/types",
  "version": "0.1.0-dev",
  "description": "Shared TypeScript types for the OrqaStudio ecosystem",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./constants": {
      "import": "./dist/constants.js",
      "types": "./dist/constants.d.ts"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orqastudio/orqastudio-types.git"
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "generate": "node scripts/generate-types.mjs"
  },
  "files": [
    "dist/"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
