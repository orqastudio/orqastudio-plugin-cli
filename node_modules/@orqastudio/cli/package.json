{
  "name": "@orqastudio/cli",
  "version": "0.1.0-dev",
  "description": "General-purpose CLI for OrqaStudio — plugin management, validation, graph browsing, version management, and dev environment maintenance.",
  "type": "module",
  "bin": {
    "orqa": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@orqastudio/types": "^0.1.0-dev",
    "@orqastudio/plugin-typescript": "^0.1.0-dev",
    "@types/node": "^25.5.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:orqastudio/orqastudio-lib-cli.git"
  },
  "license": "BSL-1.1"
}
