{
  "name": "@orqastudio/plugin-typescript",
  "version": "0.1.0-dev",
  "type": "module",
  "description": "TypeScript development infrastructure plugin for OrqaStudio — base tsconfig, ESLint configs, and config composition for plugin extensions.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tsconfig/base.json": "./src/tsconfig/base.json",
    "./tsconfig/library.json": "./src/tsconfig/library.json",
    "./tsconfig/app.json": "./src/tsconfig/app.json",
    "./eslint": {
      "import": "./dist/eslint/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "@types/node": "^22.0.0"
  },
  "files": [
    "dist",
    "src/tsconfig"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:orqastudio/orqastudio-plugin-typescript.git"
  },
  "license": "BSL-1.1"
}
