{
  "name": "@orqastudio/plugin-cli",
  "version": "0.1.0-dev",
  "displayName": "CLI Tools",
  "description": "Bundles the orqa CLI with skills for graph browsing, validation, plugin management, version management, license/readme auditing, and dev environment maintenance.",
  "category": "tooling",
  "provides": {
    "schemas": [],
    "views": [],
    "widgets": [],
    "relationships": [],
    "knowledge": [
      { "key": "cli-usage", "id": "KNOW-3198c8fb", "label": "CLI Usage" },
      { "key": "version-management", "id": "KNOW-7b5c1bda", "label": "Version Management" },
      { "key": "plugin-management", "id": "KNOW-9e1a2f6a", "label": "Plugin Management" },
      { "key": "dev-environment", "id": "KNOW-6ee6c91e", "label": "Dev Environment" },
      { "key": "self-maintenance", "id": "KNOW-6391d2a8", "label": "Self-Maintenance" },
      { "key": "license-management", "id": "KNOW-9466a88a", "label": "License Management" },
      { "key": "readme-standards", "id": "KNOW-4cc73a12", "label": "README Standards" }
    ],
    "cliTools": [
      {
        "key": "orqa-validate",
        "label": "Integrity Validator",
        "icon": "shield-check",
        "runtime": "node",
        "entrypoint": "node_modules/@orqastudio/cli/dist/cli.js",
        "args": ["validate"],
        "category": "integrity"
      },
      {
        "key": "orqa-graph-stats",
        "label": "Graph Statistics",
        "icon": "bar-chart-3",
        "runtime": "node",
        "entrypoint": "node_modules/@orqastudio/cli/dist/cli.js",
        "args": ["graph", "--stats", "--json"],
        "category": "custom"
      },
      {
        "key": "orqa-version-check",
        "label": "Version Drift Check",
        "icon": "git-compare",
        "runtime": "node",
        "entrypoint": "node_modules/@orqastudio/cli/dist/cli.js",
        "args": ["version", "check"],
        "category": "integrity"
      },
      {
        "key": "orqa-repo-license",
        "label": "License Audit",
        "icon": "scale",
        "runtime": "node",
        "entrypoint": "node_modules/@orqastudio/cli/dist/cli.js",
        "args": ["repo", "license"],
        "category": "integrity"
      },
      {
        "key": "orqa-repo-readme",
        "label": "README Audit",
        "icon": "file-text",
        "runtime": "node",
        "entrypoint": "node_modules/@orqastudio/cli/dist/cli.js",
        "args": ["repo", "readme"],
        "category": "integrity"
      }
    ],
    "hooks": [
      {
        "event": "PreCommit",
        "command": "cd libs/cli && npx tsc && cd ../.. && orqa verify",
        "description": "Rebuild CLI then run all audits before every commit"
      },
      {
        "event": "SessionStart",
        "command": "orqa version check",
        "description": "Check for version drift at session start"
      }
    ]
  }
}
